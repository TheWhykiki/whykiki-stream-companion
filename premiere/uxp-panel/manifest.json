{
  "manifestVersion": 5,
  "id": "de.whykiki.streamcompanion.poc",
  "name": "WhyKiki Stream Companion (PoC)",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "whykikiPocPanel",
      "label": {
        "default": "WhyKiki Stream Companion"
      },
      "minimumSize": { "width": 360, "height": 480 },
      "preferredDockedSize": { "width": 420, "height": 640 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
